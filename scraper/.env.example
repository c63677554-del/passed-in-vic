# ── Supabase ────────────────────────────────────────────────────────────────
# Use the SERVICE ROLE key here (server-side only — it bypasses RLS).
# Find it: Supabase Dashboard → Project Settings → API → service_role "secret".
# NEVER expose this key in the frontend or commit it to git.
SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ── Geocoding ───────────────────────────────────────────────────────────────
# Set ONE of these. If neither is set, the scraper falls back to deterministic
# MOCK coordinates scattered around Melbourne (fine for local testing only).
# Google:  https://developers.google.com/maps/documentation/geocoding
GOOGLE_MAPS_API_KEY=
# Mapbox:  https://docs.mapbox.com/api/search/geocoding/
MAPBOX_TOKEN=

# ── Source ──────────────────────────────────────────────────────────────────
# The auction-results page to scrape. Placeholder — see selectors in scraper.py.
AUCTION_RESULTS_URL=https://www.domain.com.au/auction-results/melbourne/
